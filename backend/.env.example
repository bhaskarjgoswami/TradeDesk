# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Database (Supabase Postgres direct connection) ────────
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Razorpay ──────────────────────────────────────────────
# Get keys at dashboard.razorpay.com → Settings → API Keys (use test keys first).
# Enable "International Payments" to accept non-India cards.
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-key-secret
# Webhook secret you set when creating the webhook (event: order.paid)
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Region pricing — smallest unit (paise for INR, cents for USD).
# India: ₹199/mo, ₹1,990/yr.  International: $9/mo, $90/yr.
RAZORPAY_PRICE_INR_MONTHLY=19900
RAZORPAY_PRICE_INR_ANNUAL=199000
RAZORPAY_PRICE_USD_MONTHLY=900
RAZORPAY_PRICE_USD_ANNUAL=9000

# ── App ───────────────────────────────────────────────────
PORT=8787
FRONTEND_URL=http://localhost:5173

# ── Delta Exchange (optional, per-user set via UI) ────────
# Users set their own keys in the app. These are not needed server-side.
